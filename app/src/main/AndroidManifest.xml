<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:name=".PluginApplication"
        android:allowBackup="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_cast"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_cast"
        android:supportsRtl="true"
        android:theme="@style/Theme.PowerAmpache2ChromecastPlugin"
        tools:targetApi="31" >

        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
            </intent-filter>
        </activity>

        <service
            android:name="luci.sixsixsix.powerampache2.plugin.QueueFetchService"
            android:exported="true"/>

        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="luci.sixsixsix.powerampache2.chromecastplugin.CastOptionsProvider" />
    </application>

</manifest>